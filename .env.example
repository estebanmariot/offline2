# Copier ce fichier en .env et renseigner les valeurs réelles
# Le fichier .env ne doit jamais être commité (voir .gitignore)

# --- Xano : endpoint schéma Grist ---
# URL de l'endpoint de login Xano (pour obtenir le JWT)
XANO_LOGIN_URL=

# URL de l'endpoint de récupération du schéma Grist
XANO_SCHEMA_URL=

# Credentials du compte Xano (compte de service recommandé)
XANO_EMAIL=
XANO_PASSWORD=
